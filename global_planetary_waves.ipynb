# CRITICAL CHANGE: Define sharp, discrete steps (bins) for the color bar
# This pixelates the smooth gradient into 12 high-contrast visual zones
color_levels = np.linspace(-1.5, 1.5, 13)

# Render the map with discrete level bounds
pixel_plot = global_susceptibility.plot(
